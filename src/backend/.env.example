# Environment: development | production
ENV=development

# CORS origins (comma-separated). Leave empty for dev defaults (localhost:5173).
# Production example: https://myapp.app
# CORS_ORIGINS=

# API keys (required for full functionality)
OPENAI_API_KEY=

# Upload settings (optional)
# UPLOAD_MAX_FILE_SIZE_MB=10
# UPLOAD_DIR=
# UPLOAD_TTL_SECONDS=600
